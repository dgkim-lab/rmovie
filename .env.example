AUTH_PROVIDER=keycloak
AUTH_ISSUER=http://localhost:8080/realms/rmovie
AUTH_CLIENT_ID=rmovie
AUTH_CLIENT_SECRET=replace-me
AUTH_SCOPES=openid
AUTH_SECRET=replace-with-a-long-random-value
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# Comma-separated OIDC subject (`sub`) values that are always administrators:
# ADMIN_USER_SUBJECTS=00000000-0000-0000-0000-000000000000
# Required for Cognito; optional override for Keycloak:
# AUTH_LOGOUT_URL=https://your-domain.auth.ap-northeast-2.amazoncognito.com/logout
# Optional for Cognito. Keycloak derives its account console from AUTH_ISSUER:
# AUTH_ACCOUNT_URL=https://example.com/account

GOOGLE_SHEETS_SPREADSHEET_ID=replace-me
GOOGLE_SHEETS_RANGE=Sheet1
GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

DATABASE_URL=postgresql://rmovie:replace-me@localhost:5432/rmovie
# Used only by npm run db:setup:
POSTGRES_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/postgres
RMOVIE_DB_NAME=rmovie
RMOVIE_DB_USER=rmovie
RMOVIE_DB_PASSWORD=replace-me

REDIRECT_DELAY_MS=4000
ENABLE_DEBUG_ENDPOINTS=false
RANDOM_ERROR_RATE=0.5

OTEL_SERVICE_NAME=rmovie
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

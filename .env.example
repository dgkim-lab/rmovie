AUTH_PROVIDER=keycloak
AUTH_ISSUER=http://localhost:8080/realms/rmovie
AUTH_CLIENT_ID=rmovie
AUTH_CLIENT_SECRET=replace-me
AUTH_SCOPES=openid
AUTH_SECRET=replace-with-a-long-random-value
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# Required for Cognito; optional override for Keycloak:
# AUTH_LOGOUT_URL=https://your-domain.auth.ap-northeast-2.amazoncognito.com/logout
# Optional for Cognito. Keycloak derives its account console from AUTH_ISSUER:
# AUTH_ACCOUNT_URL=https://example.com/account

GOOGLE_SHEETS_SPREADSHEET_ID=replace-me
GOOGLE_SHEETS_RANGE=Sheet1
GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

REDIRECT_DELAY_MS=4000
ENABLE_DEBUG_ENDPOINTS=false
RANDOM_ERROR_RATE=0.5

OTEL_SERVICE_NAME=rmovie
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
